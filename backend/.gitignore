# ─────────────────────────────────────────────────────────────────────────────
# Laravel — generated / compiled artefacts (never commit these)
# ─────────────────────────────────────────────────────────────────────────────
/.phpunit.cache
/node_modules
/public/build
/public/hot
/public/storage
/storage/*.key
/vendor

# ─────────────────────────────────────────────────────────────────────────────
# Environment & secrets
# .env.example IS intentionally tracked — it serves as the configuration template.
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.backup
.env.production

# ─────────────────────────────────────────────────────────────────────────────
# Local SQLite database (dev convenience — not for production)
# ─────────────────────────────────────────────────────────────────────────────
*.sqlite
*.sqlite-shm
*.sqlite-wal

# ─────────────────────────────────────────────────────────────────────────────
# Test / CI artefacts
# ─────────────────────────────────────────────────────────────────────────────
.phpunit.result.cache

# ─────────────────────────────────────────────────────────────────────────────
# Legacy Homestead / Vagrant (unused — kept for safety)
# ─────────────────────────────────────────────────────────────────────────────
Homestead.json
Homestead.yaml
auth.json

# ─────────────────────────────────────────────────────────────────────────────
# Debug logs
# ─────────────────────────────────────────────────────────────────────────────
npm-debug.log
yarn-error.log

# ─────────────────────────────────────────────────────────────────────────────
# Editor artefacts
# ─────────────────────────────────────────────────────────────────────────────
/.fleet
/.idea
/.vscode
