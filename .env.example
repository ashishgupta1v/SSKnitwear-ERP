# Phase-1 Lightning Prototype (Vite + Supabase)
# Copy this file to `.env` in the workspace root and fill in credentials.

# Switch between providers without changing the UI:
# - supabase = Phase 1 direct database writes + browser print
# - laravel  = Phase 2 Laravel API + server PDF print
VITE_DATA_PROVIDER=supabase

# Required only when VITE_DATA_PROVIDER=laravel
VITE_BACKEND_BASE_URL=http://127.0.0.1:8000

# Required when VITE_DATA_PROVIDER=supabase
# Find these in Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
